# ── Server ─────────────────────────────────────────────
PORT=8080
CLIENT_URL=http://localhost:5173

# ── Database ───────────────────────────────────────────
# Local:  mongodb://127.0.0.1:27017/parijaiyi
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/parijaiyi
MONGODB_URI=mongodb://127.0.0.1:27017/parijaiyi

# ── Auth ───────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Seeded on first run by `npm run seed`
ADMIN_EMAIL=admin@parijaiyi.com
ADMIN_PASSWORD=ChangeMe123!

# ── Cloudinary (https://cloudinary.com/console) ────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
